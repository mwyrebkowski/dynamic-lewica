@sejm_2015
new-page: true
on-arrival: {!
Q.sejm_2015_seen = 1;
function clamp(value, min, max) {
    return Math.max(min, Math.min(max, value));
}
function poll(party) {
    return Number(Q[party + "_poll"] || Q[party + "_votes"] || 0);
}
function round1(value) {
    return Math.round(value * 10) / 10;
}
function completeResult(scores) {
    const result = {};
    let subtotal = 0;
    for (const party of ["left", "razem", "pis", "ko", "psl", "konf"]) {
        result[party] = Math.max(0, Number(scores[party] || 0));
        subtotal += result[party];
    }
    if (subtotal > 98) {
        const scale = 98 / subtotal;
        subtotal = 0;
        for (const party of ["left", "razem", "pis", "ko", "psl", "konf"]) {
            result[party] = result[party] * scale;
            subtotal += result[party];
        }
    }
    result.other = Math.max(2, 100 - subtotal);
    for (const party of ["left", "razem", "pis", "ko", "psl", "konf", "other"]) result[party] = round1(result[party]);
    const roundedSubtotal = result.left + result.razem + result.pis + result.ko + result.psl + result.konf;
    result.other = round1(Math.max(0, 100 - roundedSubtotal));
    return result;
}
function seatsFor(votes, threshold, qualifyingTotal) {
    if (votes < threshold || qualifyingTotal <= 0) return 0;
    return Math.max(1, Math.round(votes / qualifyingTotal * 460));
}
let leftScore = 0;
let razemScore = 0;
const dissentPenalty = Math.max(0, (Q.left_dissent || 0) - 3);
if (Q.sejm_list_strategy == "United Left") {
    leftScore = poll("left") * 0.82 + 0.75 + (Q.left_campaign_bonus || 0) * 0.5 + ((Q.left_brand_strength || 4) - 4) * 0.22 - dissentPenalty * 0.16;
    razemScore = 3.45 + Math.max(0, 5 - (Q.left_brand_strength || 0)) * 0.12 + Math.max(0, (Q.sld_modernizers_dissent || 0) - 4) * 0.12;
} else if (Q.sejm_list_strategy == "SLD alone") {
    leftScore = poll("left") * 0.66 + 0.25 + (Q.left_campaign_bonus || 0) * 0.42 + ((Q.left_brand_strength || 4) - 4) * 0.12 - dissentPenalty * 0.14;
    razemScore = 3.75 + Math.max(0, (Q.sld_modernizers_dissent || 0) - 4) * 0.18 + Math.max(0, 4 - (Q.left_brand_strength || 0)) * 0.1;
} else {
    leftScore = poll("left") * 0.78 + 1.05 + (Q.left_campaign_bonus || 0) * 0.58 + ((Q.civil_society_capital || 3) - 3) * 0.22 + ((Q.left_brand_strength || 4) - 4) * 0.24 + Math.max(0, Q.razem_relation || 0) * 0.06 - dissentPenalty * 0.18;
    razemScore = 2.4 + Math.max(0, (Q.sld_apparatus_dissent || 0) - 3) * 0.1 + Math.max(0, -(Q.razem_relation || 0)) * 0.07;
}
leftScore = clamp(leftScore, 3.5, 14);
razemScore = clamp(razemScore, 1.5, 6.5);
const scores = {
    left: leftScore,
    razem: razemScore,
    pis: poll("pis") * 1.0 + (Q.presidential_2015_duda_win ? 2.2 : -1.2) + ((Q.pis_kaczynski_strength || 8) - 8) * 0.22 + ((Q.populist_realignment_pressure || 3) - 3) * 0.3,
    ko: poll("ko") * 0.78 + (Q.presidential_2015_duda_win ? -0.9 : 1.0) + Math.max(0, Q.ko_relation || 0) * 0.015,
    psl: poll("psl") * 0.7 + 0.2 + Math.max(0, Q.psl_relation || 0) * 0.02,
    konf: poll("konf") * 0.9 + Math.max(0, (Q.konf_mentzen_strength || 0) - 1) * 0.1,
    other: 0
};
const result = completeResult(scores);
Q.left_votes = result.left;
Q.left_poll = result.left;
Q.razem_votes = result.razem;
Q.pis_votes = result.pis;
Q.ko_votes = result.ko;
Q.psl_votes = result.psl;
Q.konf_votes = result.konf;
Q.other_votes = result.other;
Q.sejm_2015_left_result = Q.left_votes;
Q.sejm_2015_razem_result = Q.razem_votes;
Q.sejm_2015_pis_result = Q.pis_votes;
Q.sejm_2015_ko_result = Q.ko_votes;
Q.sejm_2015_psl_result = Q.psl_votes;
Q.sejm_2015_konf_result = Q.konf_votes;
Q.sejm_2015_other_result = Q.other_votes;
Q.left_threshold_safety = round1(result.left - (Q.threshold_type == "coalition" ? 8 : 5));
Q.razem_state_funding = Q.razem_votes >= 3 ? 1 : 0;
const threshold = Q.threshold_type == "coalition" ? 8 : 5;
const leftQualified = Q.left_votes >= threshold;
let qualifyingTotal = 0;
if (leftQualified) qualifyingTotal += Q.left_votes;
if (Q.razem_votes >= 5) qualifyingTotal += Q.razem_votes;
if (Q.pis_votes >= 5) qualifyingTotal += Q.pis_votes;
if (Q.ko_votes >= 5) qualifyingTotal += Q.ko_votes;
if (Q.psl_votes >= 5) qualifyingTotal += Q.psl_votes;
if (Q.konf_votes >= 5) qualifyingTotal += Q.konf_votes;
if (Q.other_votes >= 5) qualifyingTotal += Q.other_votes;
Q.left_seats = seatsFor(Q.left_votes, threshold, qualifyingTotal);
Q.razem_seats = seatsFor(Q.razem_votes, 5, qualifyingTotal);
Q.pis_seats = seatsFor(Q.pis_votes, 5, qualifyingTotal);
Q.ko_seats = seatsFor(Q.ko_votes, 5, qualifyingTotal);
Q.psl_seats = seatsFor(Q.psl_votes, 5, qualifyingTotal);
Q.konf_seats = seatsFor(Q.konf_votes, 5, qualifyingTotal);
Q.other_seats = seatsFor(Q.other_votes, 5, qualifyingTotal);
let seatTotal = Q.left_seats + Q.razem_seats + Q.pis_seats + Q.ko_seats + Q.psl_seats + Q.konf_seats + Q.other_seats;
let largestParty = "pis";
let largestVotes = Q.pis_votes;
for (const party of ["left", "razem", "ko", "psl", "konf", "other"]) {
    if (Q[party + "_votes"] > largestVotes && Q[party + "_seats"] > 0) {
        largestParty = party;
        largestVotes = Q[party + "_votes"];
    }
}
if (seatTotal != 460 && Q[largestParty + "_seats"] > 0) Q[largestParty + "_seats"] += 460 - seatTotal;
if (Q.left_votes < threshold) {
    Q.left_in_sejm = 0;
    Q.left_seats = 0;
    Q.game_over = 1;
} else {
    Q.left_in_sejm = 1;
    Q.party_resources = clamp((Q.party_resources || 0) + 2, 0, 10);
    Q.resources = Q.party_resources;
}
Q.election_records.push({year: 2015, month: 10, type: "Sejm", left: Q.left_votes, razem: Q.razem_votes, pis: Q.pis_votes, ko: Q.ko_votes, psl: Q.psl_votes, konf: Q.konf_votes, other: Q.other_votes, seats: Q.left_seats});
!}

