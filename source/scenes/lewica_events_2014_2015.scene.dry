@presidential_2015
new-page: true
on-arrival: {!
Q.presidential_2015_seen = 1;
function clamp(value, min, max) {
    return Math.max(min, Math.min(max, value));
}
function poll(party) {
    return Number(Q[party + "_poll"] || Q[party + "_votes"] || 0);
}
function round1(value) {
    return Math.round(value * 10) / 10;
}
function normalize(scores) {
    let total = 0;
    for (const party in scores) total += Math.max(0, scores[party]);
    const result = {};
    for (const party in scores) result[party] = total > 0 ? round1(Math.max(0, scores[party]) / total * 100) : 0;
    return result;
}
let leftCandidate = poll("left") * 0.28 + (Q.left_campaign_bonus || 0) * 0.08 + ((Q.media_reach || 4) - 4) * 0.05 - Math.max(0, (Q.left_dissent || 0) - 3) * 0.08;
if (Q.presidential_candidate == "Elder statesman") leftCandidate = poll("left") * 0.42 + (Q.left_brand_strength || 0) * 0.16 + (Q.left_campaign_bonus || 0) * 0.1 - Math.max(0, (Q.left_dissent || 0) - 3) * 0.07;
if (Q.presidential_candidate == "Left-wing candidate") leftCandidate = poll("left") * 0.38 + (Q.unaffiliated_left || 0) * 0.03 + (Q.under_30_left || 0) * 0.025 + (Q.left_campaign_bonus || 0) * 0.16 - Math.max(0, (Q.left_dissent || 0) - 3) * 0.06;
if (Q.presidential_candidate == "Ogorek") leftCandidate = poll("left") * 0.24 + Math.max(0, (Q.media_reach || 4) - 4) * 0.1 + (Q.left_campaign_bonus || 0) * 0.05 - Math.max(0, (Q.left_dissent || 0) - 3) * 0.1;
const scores = {
    left: clamp(leftCandidate, 1.2, 7.5),
    duda: 34.8 + (poll("pis") - 33.5) * 0.35 + ((Q.pis_kaczynski_strength || 0) - 8) * 0.2 + ((Q.russian_threat_level || 0) - 4) * 0.12,
    komorowski: 33.8 + (poll("ko") - 34) * 0.35 + ((Q.ko_tusk_strength || 0) - 7) * 0.15 - Math.max(0, (Q.populist_realignment_pressure || 0) - 3) * 0.25,
    kukiz: 20.8 + (poll("other") - 11) * 0.28 + ((Q.populist_realignment_pressure || 0) - 3) * 0.45,
    psl: 1.6 + (poll("psl") - 7) * 0.12,
    korwin: 3.3 + (poll("konf") - 5) * 0.35,
    other: 3.3
};
const result = normalize(scores);
Q.presidential_2015_result = result.left;
Q.presidential_2015_duda_result = result.duda;
Q.presidential_2015_komorowski_result = result.komorowski;
Q.presidential_2015_kukiz_result = result.kukiz;
Q.presidential_2015_psl_result = result.psl;
Q.presidential_2015_korwin_result = result.korwin;
Q.presidential_2015_other_result = result.other;
Q.presidential_2015_duda_second = round1(clamp(50.4 + (Q.presidential_2015_duda_result - Q.presidential_2015_komorowski_result) * 0.32 + (Q.presidential_2015_korwin_result - 3.3) * 0.12 + (Q.presidential_2015_kukiz_result - 20.8) * 0.05 - Math.max(0, Q.ko_relation || 0) * 0.015, 46, 54));
Q.presidential_2015_komorowski_second = round1(100 - Q.presidential_2015_duda_second);
Q.presidential_2015_duda_win = Q.presidential_2015_duda_second >= 50 ? 1 : 0;
Q.president = Q.presidential_2015_duda_win ? "Andrzej Duda" : "Bronislaw Komorowski";
Q.left_brand_strength = clamp((Q.left_brand_strength || 0) - (Q.presidential_2015_result < 3 ? 0.7 : 0.3) + (Q.presidential_2015_result >= 4 ? 0.2 : 0), 0, 10);
Q.sld_modernizers_tension = clamp((Q.sld_modernizers_tension || 0) + (Q.presidential_2015_result < 3 ? 8 : 4), 0, 150);
Q.tr_residue_tension = clamp((Q.tr_residue_tension || 0) + 4, 0, 150);
Q.gawkowski_network_tension = clamp((Q.gawkowski_network_tension || 0) + (Q.presidential_2015_result < 3 ? 8 : 3), 0, 150);
Q.sld_apparatus_tension = clamp((Q.sld_apparatus_tension || 0) + (Q.presidential_2015_result < 3 ? 3 : 1), 0, 150);
Q.pis_kaczynski_strength = clamp((Q.pis_kaczynski_strength || 0) + (Q.presidential_2015_duda_win ? 0.5 : -0.3), 0, 10);
Q.ko_tusk_strength = clamp((Q.ko_tusk_strength || 0) + (Q.presidential_2015_duda_win ? -0.5 : 0.2), 0, 10);
Q.election_records.push({year: 2015, month: 5, type: "Presidential", left: Q.presidential_2015_result, duda: Q.presidential_2015_duda_result, komorowski: Q.presidential_2015_komorowski_result, kukiz: Q.presidential_2015_kukiz_result, second_round_duda: Q.presidential_2015_duda_second});
!}

