on-arrival: {!
Q.local_2014_seen = 1;
function clamp(value, min, max) {
    return Math.max(min, Math.min(max, value));
}
function poll(party) {
    return Number(Q[party + "_poll"] || Q[party + "_votes"] || 0);
}
function round1(value) {
    return Math.round(value * 10) / 10;
}
function normalize(scores) {
    let total = 0;
    for (const party in scores) total += Math.max(0, scores[party]);
    const result = {};
    for (const party in scores) result[party] = total > 0 ? round1(Math.max(0, scores[party]) / total * 100) : 0;
    return result;
}
const structure = Q.left_regional_rebuild || 0;
const scores = {
    left: poll("left") * 0.95 + structure * 0.7 + (Q.left_campaign_bonus || 0) * 0.15 + ((Q.sld_apparatus_strength || 0) - 5) * 0.14 - Math.max(0, (Q.left_dissent || 0) - 3) * 0.12,
    ko: poll("ko") * 0.93,
    pis: poll("pis") * 0.98 + ((Q.russian_threat_level || 0) - 4) * 0.05,
    psl: poll("psl") * 1.55 + Math.max(0, Q.psl_relation || 0) * 0.03,
    konf: poll("konf") * 0.45,
    razem: 0,
    other: poll("other") * 1.12
};
const result = normalize(scores);
Q.local_2014_left_result = result.left;
Q.local_2014_ko_result = result.ko;
Q.local_2014_pis_result = result.pis;
Q.local_2014_psl_result = result.psl;
Q.local_2014_konf_result = result.konf;
Q.local_2014_other_result = result.other + result.razem;
Q.local_2014_result = Q.local_2014_left_result;
Q.left_votes = Q.local_2014_left_result;
Q.left_poll = Q.left_votes;
Q.party_resources = clamp((Q.party_resources || 0) + 1 + (structure >= 2 ? 1 : 0), 0, 10);
