@leadership_confirm
title: Confirm Leadership Team
new-page: true
on-arrival: {!
function clamp(value, min, max) {
    return Math.max(min, Math.min(max, value));
}
function flag(id) {
    return Q[id + "_advisor"] ? 1 : 0;
}
function snapshot(id) {
    return Q["advisor_snapshot_" + id] ? 1 : 0;
}
function displayName(id) {
    const names = {
        miller: "Miller",
        gawkowski: "Gawkowski",
        senyszyn: "Senyszyn",
        czarzasty: "Czarzasty",
        trela: "Trela",
        jonski: "Jonski",
        biedron: "Biedron",
        wanda_nowicka: "Nowicka",
        barbara_nowacka: "Nowacka",
        ikonowicz: "Ikonowicz",
        kwasniewski: "Kwasniewski",
        belka: "Belka",
        cimoszewicz: "Cimoszewicz"
    };
    return names[id] || id;
}
function applyAdd(id) {
    if (id == "miller") {
        Q.sld_apparatus_strength = clamp((Q.sld_apparatus_strength || 0) + 0.4, 0, 10);
        Q.sld_apparatus_tension = clamp((Q.sld_apparatus_tension || 0) - 10, 0, 150);
        Q.sld_modernizers_tension = clamp((Q.sld_modernizers_tension || 0) + 4, 0, 150);
        Q.gawkowski_network_tension = clamp((Q.gawkowski_network_tension || 0) + 4, 0, 150);
    }
    if (id == "gawkowski") {
        Q.gawkowski_network_strength = clamp((Q.gawkowski_network_strength || 0) + 0.4, 0, 10);
        Q.gawkowski_network_tension = clamp((Q.gawkowski_network_tension || 0) - 8, 0, 150);
        Q.sld_modernizers_tension = clamp((Q.sld_modernizers_tension || 0) - 4, 0, 150);
        Q.sld_apparatus_tension = clamp((Q.sld_apparatus_tension || 0) + 3, 0, 150);
    }
    if (id == "senyszyn") {
        Q.media_reach = clamp((Q.media_reach || 0) + 0.2, 0, 10);
        Q.secularization_tide = clamp((Q.secularization_tide || 0) + 0.2, 0, 10);
        Q.sld_modernizers_tension = clamp((Q.sld_modernizers_tension || 0) - 4, 0, 150);
        Q.tr_residue_tension = clamp((Q.tr_residue_tension || 0) - 3, 0, 150);
        Q.sld_apparatus_tension = clamp((Q.sld_apparatus_tension || 0) + 3, 0, 150);
    }
    if (id == "czarzasty") {
        Q.sld_apparatus_strength = clamp((Q.sld_apparatus_strength || 0) + 0.3, 0, 10);
        Q.sld_apparatus_tension = clamp((Q.sld_apparatus_tension || 0) - 6, 0, 150);
        Q.sld_modernizers_tension = clamp((Q.sld_modernizers_tension || 0) + 4, 0, 150);
    }
    if (id == "trela") {
        Q.sld_modernizers_strength = clamp((Q.sld_modernizers_strength || 0) + 0.2, 0, 10);
        Q.sld_modernizers_tension = clamp((Q.sld_modernizers_tension || 0) - 5, 0, 150);
        Q.sld_apparatus_tension = clamp((Q.sld_apparatus_tension || 0) - 3, 0, 150);
    }
    if (id == "jonski") {
        Q.media_reach = clamp((Q.media_reach || 0) + 0.2, 0, 10);
        Q.sld_modernizers_strength = clamp((Q.sld_modernizers_strength || 0) + 0.2, 0, 10);
        Q.sld_apparatus_tension = clamp((Q.sld_apparatus_tension || 0) + 3, 0, 150);
    }
    if (id == "biedron") {
        Q.tr_residue_strength = clamp((Q.tr_residue_strength || 0) + 0.3, 0, 10);
        Q.tr_residue_tension = clamp((Q.tr_residue_tension || 0) - 8, 0, 150);
        Q.sld_apparatus_tension = clamp((Q.sld_apparatus_tension || 0) + 8, 0, 150);
    }
    if (id == "wanda_nowicka") {
        Q.tr_residue_tension = clamp((Q.tr_residue_tension || 0) - 7, 0, 150);
        Q.civil_society_capital = clamp((Q.civil_society_capital || 0) + 0.2, 0, 10);
        Q.sld_apparatus_tension = clamp((Q.sld_apparatus_tension || 0) + 4, 0, 150);
    }
    if (id == "barbara_nowacka") {
        Q.tr_residue_tension = clamp((Q.tr_residue_tension || 0) - 6, 0, 150);
        Q.pps_up_tension = clamp((Q.pps_up_tension || 0) - 4, 0, 150);
        Q.sld_apparatus_tension = clamp((Q.sld_apparatus_tension || 0) + 6, 0, 150);
    }
    if (id == "ikonowicz") {
        Q.pps_up_strength = clamp((Q.pps_up_strength || 0) + 0.3, 0, 10);
        Q.pps_up_tension = clamp((Q.pps_up_tension || 0) - 8, 0, 150);
        Q.sld_apparatus_tension = clamp((Q.sld_apparatus_tension || 0) + 5, 0, 150);
        Q.ko_relation -= 1;
    }
    if (id == "kwasniewski") {
        Q.left_brand_strength = clamp((Q.left_brand_strength || 0) + 0.3, 0, 10);
        Q.sld_apparatus_tension = clamp((Q.sld_apparatus_tension || 0) - 3, 0, 150);
        Q.ko_relation += 1;
    }
    if (id == "belka") {
        Q.public_finance_pressure = clamp((Q.public_finance_pressure || 0) - 0.2, 0, 10);
        Q.pps_up_tension = clamp((Q.pps_up_tension || 0) + 3, 0, 150);
        Q.ko_relation += 1;
    }
    if (id == "cimoszewicz") {
        Q.eu_institutional_alignment = clamp((Q.eu_institutional_alignment || 0) + 0.2, 0, 10);
        Q.sld_modernizers_tension = clamp((Q.sld_modernizers_tension || 0) - 3, 0, 150);
        Q.sld_apparatus_tension = clamp((Q.sld_apparatus_tension || 0) + 3, 0, 150);
    }
}
function applyRemove(id) {
    if (id == "miller") {
        Q.sld_apparatus_tension = clamp((Q.sld_apparatus_tension || 0) + 16, 0, 150);
        Q.gawkowski_network_strength = clamp((Q.gawkowski_network_strength || 0) + 0.3, 0, 10);
    }
    if (id == "gawkowski") {
        Q.sld_modernizers_tension = clamp((Q.sld_modernizers_tension || 0) + 10, 0, 150);
        Q.gawkowski_network_tension = clamp((Q.gawkowski_network_tension || 0) + 12, 0, 150);
        Q.left_regional_rebuild = Math.max(0, (Q.left_regional_rebuild || 0) - 0.5);
    }
    if (id == "senyszyn") {
        Q.sld_modernizers_tension = clamp((Q.sld_modernizers_tension || 0) + 6, 0, 150);
        Q.tr_residue_tension = clamp((Q.tr_residue_tension || 0) + 5, 0, 150);
        Q.sld_apparatus_tension = clamp((Q.sld_apparatus_tension || 0) - 3, 0, 150);
    }
    if (id == "czarzasty") {
        Q.sld_apparatus_tension = clamp((Q.sld_apparatus_tension || 0) + 10, 0, 150);
        Q.gawkowski_network_tension = clamp((Q.gawkowski_network_tension || 0) - 2, 0, 150);
    }
    if (id == "trela") {
        Q.sld_modernizers_tension = clamp((Q.sld_modernizers_tension || 0) + 6, 0, 150);
        Q.left_regional_rebuild = Math.max(0, (Q.left_regional_rebuild || 0) - 0.3);
    }
    if (id == "jonski") {
        Q.media_reach = Math.max(0, (Q.media_reach || 0) - 0.2);
        Q.sld_modernizers_tension = clamp((Q.sld_modernizers_tension || 0) + 5, 0, 150);
    }
    if (id == "biedron") {
        Q.tr_residue_tension = clamp((Q.tr_residue_tension || 0) + 12, 0, 150);
        Q.sld_apparatus_tension = clamp((Q.sld_apparatus_tension || 0) - 3, 0, 150);
    }
    if (id == "wanda_nowicka") {
        Q.tr_residue_tension = clamp((Q.tr_residue_tension || 0) + 9, 0, 150);
        Q.civil_society_capital = Math.max(0, (Q.civil_society_capital || 0) - 0.2);
    }
    if (id == "barbara_nowacka") {
        Q.tr_residue_tension = clamp((Q.tr_residue_tension || 0) + 8, 0, 150);
        Q.pps_up_tension = clamp((Q.pps_up_tension || 0) + 5, 0, 150);
        Q.nowacka_unity_mandate = Math.max(0, (Q.nowacka_unity_mandate || 0) - 1);
    }
    if (id == "ikonowicz") {
        Q.pps_up_tension = clamp((Q.pps_up_tension || 0) + 12, 0, 150);
        Q.ko_relation += 1;
    }
    if (id == "kwasniewski") {
        Q.left_brand_strength = Math.max(0, (Q.left_brand_strength || 0) - 0.2);
        Q.sld_apparatus_tension = clamp((Q.sld_apparatus_tension || 0) + 4, 0, 150);
    }
    if (id == "belka") {
        Q.pps_up_tension = clamp((Q.pps_up_tension || 0) - 2, 0, 150);
        Q.ko_relation -= 1;
    }
    if (id == "cimoszewicz") {
        Q.sld_modernizers_tension = clamp((Q.sld_modernizers_tension || 0) + 5, 0, 150);
        Q.eu_institutional_alignment = Math.max(0, (Q.eu_institutional_alignment || 0) - 0.1);
    }
}
const ids = ["miller", "gawkowski", "senyszyn", "czarzasty", "trela", "jonski", "biedron", "wanda_nowicka", "barbara_nowacka", "ikonowicz", "kwasniewski", "belka", "cimoszewicz"];
const added = [];
const removed = [];
let count = 0;
for (const id of ids) {
    if (flag(id)) count += 1;
    if (!snapshot(id) && flag(id)) {
        added.push(displayName(id));
        applyAdd(id);
    }
    if (snapshot(id) && !flag(id)) {
        removed.push(displayName(id));
        applyRemove(id);
    }
}
Q.n_advisors = count;
if (added.length || removed.length) {
    Q.month_actions += 1;
    Q.advisor_roster_timer = 6;
    Q.advisor_roster_changes = (Q.advisor_roster_changes || 0) + 1;
    Q.advisor_last_roster_change = "Added: " + (added.length ? added.join(", ") : "none") + "; removed: " + (removed.length ? removed.join(", ") : "none");
} else {
    Q.advisor_roster_timer = 0;
    Q.advisor_last_roster_change = "No leadership changes";
}
Q.advisor_roster_changed = 0;
!}

The leadership team is confirmed.

Last change: [+ advisor_last_roster_change +]

- @post_event: Continue.

@leadership_cancel
title: Cancel Leadership Changes
new-page: true
on-arrival: {!
Q.miller_advisor = Q.advisor_snapshot_miller || 0;
Q.gawkowski_advisor = Q.advisor_snapshot_gawkowski || 0;
Q.senyszyn_advisor = Q.advisor_snapshot_senyszyn || 0;
Q.czarzasty_advisor = Q.advisor_snapshot_czarzasty || 0;
Q.trela_advisor = Q.advisor_snapshot_trela || 0;
Q.jonski_advisor = Q.advisor_snapshot_jonski || 0;
Q.biedron_advisor = Q.advisor_snapshot_biedron || 0;
Q.wanda_nowicka_advisor = Q.advisor_snapshot_wanda_nowicka || 0;
Q.barbara_nowacka_advisor = Q.advisor_snapshot_barbara_nowacka || 0;
Q.ikonowicz_advisor = Q.advisor_snapshot_ikonowicz || 0;
Q.kwasniewski_advisor = Q.advisor_snapshot_kwasniewski || 0;
Q.belka_advisor = Q.advisor_snapshot_belka || 0;
Q.cimoszewicz_advisor = Q.advisor_snapshot_cimoszewicz || 0;
Q.n_advisors = Q.advisor_snapshot_count || 0;
Q.advisor_roster_changed = 0;
Q.advisor_last_roster_change = "Cancelled";
!}

No leadership changes are made.

