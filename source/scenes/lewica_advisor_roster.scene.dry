title: Advisor Panel
new-page: true
is-special: true
view-if: started
on-arrival: {!
function advisorNames() {
    const names = [];
    if (Q.miller_advisor) names.push("Leszek Miller");
    if (Q.gawkowski_advisor) names.push("Krzysztof Gawkowski");
    if (Q.senyszyn_advisor) names.push("Joanna Senyszyn");
    if (Q.czarzasty_advisor) names.push("Wlodzimierz Czarzasty");
    if (Q.trela_advisor) names.push("Tomasz Trela");
    if (Q.jonski_advisor) names.push("Dariusz Jonski");
    if (Q.biedron_advisor) names.push("Robert Biedron");
    if (Q.wanda_nowicka_advisor) names.push("Wanda Nowicka");
    if (Q.barbara_nowacka_advisor) names.push("Barbara Nowacka");
    if (Q.ikonowicz_advisor) names.push("Piotr Ikonowicz");
    if (Q.kwasniewski_advisor) names.push("Aleksander Kwasniewski");
    if (Q.belka_advisor) names.push("Marek Belka");
    if (Q.cimoszewicz_advisor) names.push("Wlodzimierz Cimoszewicz");
    return names.length ? names.join(", ") : "none";
}
Q.active_advisor_summary = advisorNames();
Q.advisor_action_status = Q.advisor_action_timer > 0 ? Q.advisor_action_timer + " months" : "available";
Q.advisor_roster_status = Q.advisor_roster_timer > 0 ? Q.advisor_roster_timer + " months" : "available";
!}

= Advisor Panel

Active advisors: **[+ active_advisor_summary +]**

Advisor action cooldown: [+ advisor_action_status +]  
Switch leadership cooldown: [+ advisor_roster_status +]  
Roster size: [+ n_advisors +] / [+ max_advisors +]

The active leadership team determines which Advisor Action cards can be drawn. Switching leadership opens the roster, lets you remove and add advisors, and only spends one monthly action when you confirm a changed roster.

- @switch_leadership_start: Switch leadership.
- @root: Return to main.

@switch_leadership_card
title: Switch Leadership
new-page: true
is-card: true
is-pinned-card: true
card-image: img/portraits/placeholder.jpg
view-if: started and advisor_roster_timer <= 0
choose-if: month_actions < actions_per_month
unavailable-subtitle: No monthly action remaining.
go-to: switch_leadership_start

@switch_leadership_start
title: Switch Leadership
new-page: true
choose-if: advisor_roster_timer <= 0 and month_actions < actions_per_month
unavailable-subtitle: [? if advisor_roster_timer > 0 : Leadership can be switched again in [+ advisor_roster_timer +] months. ?][? if month_actions >= actions_per_month : No monthly action remaining. ?]
on-arrival: {!
function flag(value) {
    return value ? 1 : 0;
}
Q.advisor_snapshot_miller = flag(Q.miller_advisor);
Q.advisor_snapshot_gawkowski = flag(Q.gawkowski_advisor);
Q.advisor_snapshot_senyszyn = flag(Q.senyszyn_advisor);
Q.advisor_snapshot_czarzasty = flag(Q.czarzasty_advisor);
Q.advisor_snapshot_trela = flag(Q.trela_advisor);
Q.advisor_snapshot_jonski = flag(Q.jonski_advisor);
Q.advisor_snapshot_biedron = flag(Q.biedron_advisor);
Q.advisor_snapshot_wanda_nowicka = flag(Q.wanda_nowicka_advisor);
Q.advisor_snapshot_barbara_nowacka = flag(Q.barbara_nowacka_advisor);
Q.advisor_snapshot_ikonowicz = flag(Q.ikonowicz_advisor);
Q.advisor_snapshot_kwasniewski = flag(Q.kwasniewski_advisor);
Q.advisor_snapshot_belka = flag(Q.belka_advisor);
Q.advisor_snapshot_cimoszewicz = flag(Q.cimoszewicz_advisor);
Q.advisor_snapshot_count = Q.n_advisors || 0;
Q.advisor_roster_changed = 0;
!}
go-to: leadership_main

@leadership_main
title: Switch Leadership
new-page: true
on-arrival: {!
function countAdvisors() {
    const ids = ["miller", "gawkowski", "senyszyn", "czarzasty", "trela", "jonski", "biedron", "wanda_nowicka", "barbara_nowacka", "ikonowicz", "kwasniewski", "belka", "cimoszewicz"];
    let count = 0;
    for (const id of ids) {
        if (Q[id + "_advisor"]) count += 1;
    }
    return count;
}
function advisorNames() {
    const names = [];
    if (Q.miller_advisor) names.push("Leszek Miller");
    if (Q.gawkowski_advisor) names.push("Krzysztof Gawkowski");
    if (Q.senyszyn_advisor) names.push("Joanna Senyszyn");
    if (Q.czarzasty_advisor) names.push("Wlodzimierz Czarzasty");
    if (Q.trela_advisor) names.push("Tomasz Trela");
    if (Q.jonski_advisor) names.push("Dariusz Jonski");
    if (Q.biedron_advisor) names.push("Robert Biedron");
    if (Q.wanda_nowicka_advisor) names.push("Wanda Nowicka");
    if (Q.barbara_nowacka_advisor) names.push("Barbara Nowacka");
    if (Q.ikonowicz_advisor) names.push("Piotr Ikonowicz");
    if (Q.kwasniewski_advisor) names.push("Aleksander Kwasniewski");
    if (Q.belka_advisor) names.push("Marek Belka");
    if (Q.cimoszewicz_advisor) names.push("Wlodzimierz Cimoszewicz");
    return names.length ? names.join(", ") : "none";
}
Q.n_advisors = countAdvisors();
Q.active_advisor_summary = advisorNames();
Q.open_advisor_slots = Math.max(0, (Q.max_advisors || 3) - Q.n_advisors);
!}

= Switch Leadership

Active advisors: **[+ active_advisor_summary +]**  
Open slots: [+ open_advisor_slots +]  
[? if advisor_roster_changed: Unconfirmed roster changes are pending. ?]

Changing the leadership team changes the Advisor Actions deck. Confirming any changed roster spends this month's action and starts a six-month leadership cooldown.

- @leadership_remove_menu: Remove advisors.
- @leadership_add_menu: Add advisors.
- @leadership_confirm: Confirm leadership team.
- @leadership_cancel: Cancel changes.

